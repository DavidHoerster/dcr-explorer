<div class="d-flex align-items-center gap-3 @(Small ? "spinner-inline" : "spinner-block")">
    <div class="spinner-border text-primary @(Small ? "spinner-border-sm" : null)" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <span class="text-secondary">@Message</span>
</div>

@code {
    [Parameter]
    public string Message { get; set; } = "Loading...";

    [Parameter]
    public bool Small { get; set; }
}
