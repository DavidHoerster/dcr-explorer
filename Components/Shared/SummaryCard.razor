@if (Data is not null)
{
    <div class="card border-0 shadow-sm summary-card">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
                <div>
                    <div class="small text-uppercase text-secondary fw-semibold">Workspace</div>
                    <h2 class="h3 mb-1">@Data.WorkspaceName</h2>
                    <div class="text-secondary text-break">@Data.WorkspaceResourceId</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge status-active">Active DCRs: @Data.ActiveDcrs</span>
                    <span class="badge status-orphaned">Orphaned DCRs: @Data.OrphanedDcrs</span>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-sm-6 col-xl-3">
                    <div class="metric-tile">
                        <div class="metric-label">Total DCRs</div>
                        <div class="metric-value">@Data.TotalDcrs</div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="metric-tile">
                        <div class="metric-label">Data flows</div>
                        <div class="metric-value">@Data.TotalDataFlows</div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="metric-tile">
                        <div class="metric-label">With transform</div>
                        <div class="metric-value">@Data.WithTransform</div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="metric-tile">
                        <div class="metric-label">Without transform</div>
                        <div class="metric-value">@Data.WithoutTransform</div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="metric-tile">
                        <div class="metric-label">7d volume</div>
                        <div class="metric-value">@($"{Data.TotalVolume7dGb:N2} GB")</div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="metric-tile">
                        <div class="metric-label">30d volume</div>
                        <div class="metric-value">@($"{Data.TotalVolume30dGb:N2} GB")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public DcrReportData Data { get; set; } = default!;
}
