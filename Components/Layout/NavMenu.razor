<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid align-items-start flex-column">
        <a class="navbar-brand mb-1" href="">DCR Detail Viewer</a>
        <span class="sidebar-subtitle">Analyze data collection rules for a Log Analytics workspace.</span>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler')?.click()">
    <nav class="nav flex-column px-2 pb-3">
        <div class="nav-item px-2">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon">🏠</span>
                <span>Home</span>
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="workspace-picker">
                        <span class="nav-icon">🧭</span>
                        <span>Select workspace</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="px-3 pt-3">
            <AuthorizeView>
                <Authorized>
                    <div class="signed-in-card">
                        <div class="small text-uppercase text-muted fw-semibold">Signed in</div>
                        <div class="text-truncate">@context.User.Identity?.Name</div>
                        <a class="btn btn-sm btn-outline-light mt-3" href="MicrosoftIdentity/Account/SignOut">Sign out</a>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="signed-in-card">
                        <div class="small text-uppercase text-muted fw-semibold">Authentication</div>
                        <div>Use your Entra ID account to enumerate subscriptions and workspaces.</div>
                        <a class="btn btn-sm btn-primary mt-3" href="MicrosoftIdentity/Account/SignIn">Sign in</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>
</div>
